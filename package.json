{
  "name": "ran-commit",
  "displayName": "Ran - AI Conventional Commit",
  "description": "AI-powered git commit message generator using claude-cli, perplexity, vscode",
  "version": "0.0.15",
  "publisher": "skyran",
  "keywords": [
    "git",
    "commit",
    "ai",
    "claude",
    "perplexity",
    "copilot",
    "scm",
    "conventional-commits"
  ],
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/skyran1278/ran-commit.git"
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "AI",
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ranCommit.generateCommit",
        "title": "Generate Commit Message",
        "icon": "$(sparkle)"
      },
      {
        "command": "ranCommit.storePerplexityApiKey",
        "title": "Ran - AI Conventional Commit: Store Perplexity API Key"
      },
      {
        "command": "ranCommit.selectModel",
        "title": "Ran - AI Conventional Commit: Select Model"
      }
    ],
    "configuration": {
      "title": "Ran - AI Conventional Commit",
      "properties": {
        "ranCommit.method": {
          "type": "string",
          "enum": [
            "auto",
            "vscode-lm",
            "claude-cli",
            "perplexity"
          ],
          "default": "auto",
          "description": "How to generate commit messages. `auto` tries vscode.lm first, falls back to Claude CLI. `vscode-lm` requires a model provider (e.g. GitHub Copilot). `claude-cli` requires the `claude` CLI on PATH. `perplexity` uses the Perplexity API (set key via 'Git Commit: Store Perplexity API Key')."
        },
        "ranCommit.claudeCliModel": {
          "type": "string",
          "enum": [
            "",
            "sonnet",
            "opus",
            "haiku",
            "sonnet[1m]",
            "opus[1m]",
            "opusplan"
          ],
          "enumItemLabels": [
            "Default",
            "Sonnet",
            "Opus",
            "Haiku",
            "Sonnet (1M context)",
            "Opus (1M context)",
            "Opus Plan"
          ],
          "default": "",
          "markdownDescription": "Model alias to pass to `claude --model`. See [model config docs](https://code.claude.com/docs/en/model-config) for details."
        },
        "ranCommit.perplexityModel": {
          "type": "string",
          "enum": [
            "",
            "perplexity/sonar",
            "anthropic/claude-sonnet-4-6",
            "anthropic/claude-opus-4-6",
            "openai/gpt-5.4",
            "google/gemini-2.5-pro",
            "google/gemini-3.1-pro-preview",
            "google/gemini-3-flash-preview"
          ],
          "enumItemLabels": [
            "Default (perplexity/sonar)",
            "Perplexity Sonar",
            "Claude Sonnet 4.6",
            "Claude Opus 4.6",
            "GPT-5.4",
            "Gemini 2.5 Pro",
            "Gemini 3.1 Pro Preview",
            "Gemini 3 Flash Preview"
          ],
          "default": "",
          "markdownDescription": "Perplexity Agent API model. See [Perplexity models](https://docs.perplexity.ai/docs/agent-api/models) for the full list."
        },
        "ranCommit.vscodeLmModel": {
          "type": "string",
          "default": "",
          "markdownDescription": "Model for `vscode-lm` / `auto`. Format: `vendor/family` (e.g. `copilot/gpt-4o`). Use the **Select Model** command to pick from installed models. Leave empty to use any available model."
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "ranCommit.generateCommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "test": "vscode-test",
    "prepare": "husky",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.107.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.1",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
