{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "hooks": {
    "before:init": [
      "pnpm run check-types",
      "pnpm run lint",
      "pnpm format",
      "pnpm test"
    ],
    "after:bump": "node scripts/generate-changelog.mjs ${version}",
    "after:release": "pnpm dlx @vscode/vsce publish --no-dependencies"
  },
  "git": {
    "commitMessage": "chore: release v${version}"
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  }
}
